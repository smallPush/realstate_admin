{% extends 'base.html.twig' %}

{% block title %}Admin — Apartamentos{% endblock %}

{% block body %}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1>Panel de administración</h1>
            <p>Gestiona todos los apartamentos del sistema</p>
        </div>
        <div>
            <form action="{{ path('apartment_admin_sync') }}" method="POST" style="display: inline;">
                <button type="submit" class="btn-edit" style="background: var(--accent); color: white; border: none; padding: 0.5rem 1rem; border-radius: var(--radius-sm); cursor: pointer;">
                    🔄 Sincronizar con Vapi
                </button>
            </form>
        </div>
    </div>

    {% if apartments is empty %}
        <div class="table-card">
            <div class="empty-state">
                <div class="icon">🏢</div>
                <p>No hay apartamentos registrados todavía.</p>
            </div>
        </div>
    {% else %}
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Dirección</th>
                        <th>Precio</th>
                        <th>Sincro Vapi</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for apartment in apartments %}
                        <tr>
                            <td>{{ apartment.id }}</td>
                            <td>{{ apartment.name }}</td>
                            <td>{{ apartment.address }}</td>
                            <td class="price">{{ apartment.price|number_format(0, ',', '.') }} €/mes</td>
                            <td>
                                {% if apartment.vapiSyncedAt %}
                                    <span style="font-size: 0.75rem; color: var(--text-secondary);">
                                        {{ apartment.vapiSyncedAt|date('d/m H:i') }}
                                    </span>
                                {% else %}
                                    <span style="font-size: 0.75rem; color: var(--text-secondary); opacity: 0.5;">
                                        Pendiente
                                    </span>
                                {% endif %}
                            </td>
                            <td class="text-secondary" style="font-size: 0.85rem;">{{ apartment.description|slice(0, 50) }}{{ apartment.description|length > 50 ? '...' : '' }}</td>
                            <td>
                                {% if apartment.available %}
                                    <span class="badge badge-available">Disponible</span>
                                {% else %}
                                    <span class="badge badge-unavailable">No disponible</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('apartment_edit', {id: apartment.id}) }}" class="btn-edit">
                                    ✏️ Editar
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
