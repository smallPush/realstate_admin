{% extends 'base.html.twig' %}

{% block title %}Editar — {{ apartment.name }}{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Editar apartamento</h1>
        <p>{{ apartment.name }} — {{ apartment.address }}</p>
    </div>

    <div class="form-card">
        {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.address) }}
                {{ form_widget(form.address) }}
                {{ form_errors(form.address) }}
            </div>

            <div class="form-group">
                {{ form_label(form.price) }}
                {{ form_widget(form.price) }}
                {{ form_errors(form.price) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-group">
                <div class="checkbox-wrapper">
                    {{ form_widget(form.isAvailable) }}
                    <label class="checkbox-label" for="{{ form.isAvailable.vars.id }}">Disponible para alquiler</label>
                </div>
                {{ form_errors(form.isAvailable) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">💾 Guardar cambios</button>
                <a href="{{ path('apartment_admin_index') }}" class="btn btn-secondary">← Volver al listado</a>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
