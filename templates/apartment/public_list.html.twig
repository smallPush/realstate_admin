{% extends 'base.html.twig' %}

{% block title %}Apartamentos disponibles{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Nuestros apartamentos</h1>
        <p>Listado de apartamentos en gestión</p>
    </div>

    {% if apartments is empty %}
        <div class="table-card">
            <div class="empty-state">
                <div class="icon">🏢</div>
                <p>No hay apartamentos registrados todavía.</p>
            </div>
        </div>
    {% else %}
        <div class="public-grid">
            {% for apartment in apartments %}
                <div class="public-card">
                    <div class="public-card-icon">🏠</div>
                    <span class="public-card-name">{{ apartment.name }}</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <style>
        .public-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1rem;
        }

        .public-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: var(--transition);
        }

        .public-card:hover {
            border-color: var(--accent);
            background: var(--bg-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        }

        .public-card-icon {
            width: 44px;
            height: 44px;
            background: var(--accent-glow);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .public-card-name {
            font-weight: 600;
            font-size: 1rem;
            color: var(--text-primary);
        }
    </style>
{% endblock %}
