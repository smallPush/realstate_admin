{% extends 'base.html.twig' %}

{% block title %}Editar Usuario{% endblock %}

{% block body %}
    <div style="margin-bottom: 2rem;">
        <a href="{{ path('user_index') }}" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
            ← Volver al listado
        </a>
        <h1 style="font-size: 1.5rem; color: var(--text-primary); margin: 0.5rem 0 0 0;">Editar Usuario: {{ user.username }}</h1>
    </div>

    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.username) }}
                {{ form_widget(form.username) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first) }}
                <small style="color: var(--text-muted); display: block; margin-top: 0.25rem;">(Dejar en blanco para mantener la actual)</small>
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second) }}
            </div>

            <div class="form-group">
                {{ form_label(form.apartmentGroups) }}
                {{ form_widget(form.apartmentGroups) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Actualizar Usuario</button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
