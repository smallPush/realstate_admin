{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión{% endblock %}

{% block body %}
    <div class="login-wrapper">
        <div class="form-card login-card">
            <div class="login-header">
                <div class="login-icon">🔐</div>
                <h1>Acceso Admin</h1>
                <p>Introduce tus credenciales para acceder al panel</p>
            </div>

            {% if error %}
                <div class="flash flash-error" style="margin-bottom: 1.5rem;">
                    ✕ {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">
                <div class="form-group">
                    <label for="inputUsername">Usuario</label>
                    <input type="text" id="inputUsername" name="_username" value="{{ last_username }}" autocomplete="username" autofocus placeholder="admin">
                </div>

                <div class="form-group">
                    <label for="inputPassword">Contraseña</label>
                    <input type="password" id="inputPassword" name="_password" autocomplete="current-password" placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.85rem;">
                    Iniciar sesión →
                </button>
            </form>

            <div class="login-footer">
                <a href="{{ path('apartment_public_list') }}">← Volver al listado público</a>
            </div>
        </div>
    </div>

    <style>
        .login-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 64px - 4rem);
        }

        .login-card {
            width: 100%;
            max-width: 420px;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-icon {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
        }

        .login-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.03em;
            margin-bottom: 0.25rem;
        }

        .login-header p {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
        }

        .login-footer a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .login-footer a:hover {
            color: var(--accent);
        }
    </style>
{% endblock %}
