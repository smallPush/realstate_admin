# Default .env for RealState Admin
# ----------------------------------------------------------------------------------
# This file is a template. DO NOT put real secrets here.
# Instead, create a file named ".env.local" in this directory and override
# the variables there. See Symfony documentation for more details:
# https://symfony.com/doc/current/configuration.html#infrastructure-related-configuration
# ----------------------------------------------------------------------------------

APP_ENV=prod
APP_SECRET=__REPLACE_ME__

# Docker database connection (overridden by Dokploy)
# Example: postgresql://app:password@database:5432/app?serverVersion=16&charset=utf8
DATABASE_URL="postgresql://app:__REPLACE_ME__@database:5432/app?serverVersion=16&charset=utf8"

# Vapi Integration
VAPI_API_KEY=""
VAPI_ASSISTANT_ID=""

# Application
APP_SHARE_DIR="var/share"
DEFAULT_URI="http://localhost"
ADMIN_PASSWORD=""
VAPI_WEBHOOK_SECRET=""
